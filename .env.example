# EnerFlow – Environment Variables
# Copy this file to `.env` (project root, next to docker-compose.yml) and fill in your
# actual local values. Never commit the real `.env` file — it's already in .gitignore.

# --- PostgreSQL ---
# Used by both the postgres and app containers. Note: only applied on the FIRST startup
# of an empty database volume. Change it later? Run `docker compose down -v` first.
POSTGRES_PASSWORD=change_me

# --- Heat Pump (myUplink Cloud REST API — OAuth2 client secret) ---
HEATPUMP_PASSWORD=change_me

# --- Sonnen Battery (local REST API) ---
SONNEN_HOST=192.168.xxx.xxx
SONNEN_API_TOKEN=change_me

# --- Application security ---
# Initial password for the default 'admin' user created on first startup.
ENERFLOW_DEFAULT_ADMIN_PASSWORD=change_me
# JWT signing secret — must be at least 32 bytes (256 bit) for HS256.
ENERFLOW_JWT_SECRET=change_me_min_32_bytes_long_secret
# Token validity in milliseconds. 86400000 = 24 hours.
ENERFLOW_JWT_EXPIRATION_MS=86400000
